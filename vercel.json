{
  "version": 2,
  "rewrites": [
    { "source": "/api/health",       "destination": "/api/health" },
    { "source": "/api/sync",         "destination": "/api/sync" },
    { "source": "/api/teams",        "destination": "/api/teams" },
    { "source": "/api/reports",      "destination": "/api/reports" },
    { "source": "/api/reports/(.*)", "destination": "/api/reports" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ]
}