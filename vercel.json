{
  "version": 2,
  "rewrites": [
    { "source": "/api/health",           "destination": "/api/health" },
    { "source": "/api/sync",             "destination": "/api/sync" },
    { "source": "/api/activities",       "destination": "/api/activities" },
    { "source": "/api/activities/(.*)",  "destination": "/api/activities" },
    { "source": "/api/analysis",         "destination": "/api/analysis" },
    { "source": "/api/teams",            "destination": "/api/teams" },
    { "source": "/api/reports",          "destination": "/api/reports" },
    { "source": "/api/reports/(.*)",     "destination": "/api/reports" },
    { "source": "/report",               "destination": "/report.html" },
    { "source": "/(.*)",                 "destination": "/index.html" }
  ]
}
